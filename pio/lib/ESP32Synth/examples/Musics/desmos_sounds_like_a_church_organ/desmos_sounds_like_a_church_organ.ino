import math

def gerar_codigo_esp32(input_texto):
    # Configurações
    BASE_FREQ_CENTIHZ = 20765  # gs3 (G#3) do seu header = 20765
    MAX_VOICES = 64
    DELAY_MS = 500
    
    # Dicionário para rastrear o estado: { nota_float: id_voz_int }
    vozes_ativas = {} 
    
    output_cpp = []
    output_cpp.append("// Código gerado para ESP32Synth")
    output_cpp.append("void tocarSequencia() {")
    
    # Divide por linhas e remove vazias
    linhas = [l.strip() for l in input_texto.strip().split('\n') if l.strip()]
    
    for i, linha in enumerate(linhas):
        output_cpp.append(f"\n    // --- Linha {i+1}: {linha} ---")
        
        # 1. Parsear as notas da linha atual
        notas_texto = linha.split(',')
        notas_atuais = set()
        
        for n in notas_texto:
            try:
                val = float(n.strip())
                notas_atuais.add(val)
            except ValueError:
                continue # Pula se for texto inválido
        
        # 2. Identificar notas que sumiram (Note Off)
        # Notas que estavam ativas, mas não estão na lista atual
        notas_para_desligar = []
        for nota, voz_id in list(vozes_ativas.items()):
            if nota not in notas_atuais:
                output_cpp.append(f"    synth.noteOff({voz_id}); // Nota {nota} parou")
                notas_para_desligar.append(nota)
        
        # Remove do rastreamento
        for nota in notas_para_desligar:
            del vozes_ativas[nota]
            
        # 3. Identificar notas novas (Note On)
        # Notas que estão na lista atual, mas não estavam ativas
        for nota in notas_atuais:
            if nota not in vozes_ativas:
                # Precisa alocar uma voz livre
                voz_livre = -1
                
                # Procura slot de 0 a 63 que não esteja sendo usado
                ids_usados = set(vozes_ativas.values())
                for v in range(MAX_VOICES):
                    if v not in ids_usados:
                        voz_livre = v
                        break
                
                if voz_livre != -1:
                    # Calcula frequência: Freq = Base * 2^(semitons/12)
                    # Usamos float para o calculo, depois convertemos para int (CentiHz)
                    ratio = pow(2.0, nota / 12.0)
                    freq_centihz = int(BASE_FREQ_CENTIHZ * ratio)
                    
                    output_cpp.append(f"    synth.noteOn({voz_livre}, {freq_centihz}, 127); // Nota {nota} (Freq: {freq_centihz})")
                    vozes_ativas[nota] = voz_livre
                else:
                    output_cpp.append(f"    // ERRO: Sem vozes livres para a nota {nota}!")

        # 4. Adicionar Delay
        output_cpp.append(f"    delay({DELAY_MS});")

    # Finalização: Desligar tudo que sobrou no final
    output_cpp.append("\n    // Finalizando todas as notas restantes")
    for nota, voz_id in vozes_ativas.items():
        output_cpp.append(f"    synth.noteOff({voz_id});")
    
    output_cpp.append("}")
    
    return "\n".join(output_cpp)

