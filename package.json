{
  "name": "@jotcad/core",
  "version": "0.0.1",
  "description": "Javascript CAD",
  "repository": "https://github.com/jsxcad/JSxCAD",
  "type": "module",
  "scripts": {
    "start": "node orchestrator.js",
    "start:vfs": "node fs/serve.js",
    "depcheck": "npm run depcheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lintfix": "npm run lintfix --workspaces --if-present",
    "prettier": "prettier --write .",
    "cli": "node cli/cli.js",
    "rollup": "npm run rollup --workspaces --if-present",
    "unit_test": "cd geo/test && ./run_unit_tests.sh && cd ../../fs && npm test",
    "integration_test": "xvfb-run -s '-ac -screen 0 1280x1024x24' node --test --test-timeout=30000 --test-force-exit fs/test/*.test.js geo/test/*.test.js",
    "test": "npm run unit_test && npm run integration_test",
    "tests": "xvfb-run -s '-ac -screen 0 1280x1024x24' node --test --test-timeout=30000 --test-force-exit '*/*.test.js'",
    "lintfix_one": "npx eslint --fix $1",
    "debug": "http-server . -p 9090"
  },
  "contributors": [],
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@babel/eslint-parser": "^7.27.0",
    "eslint": "^9.0.0",
    "eslint-config-standard": "^12.0.0",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-jsdoc": "^46.4.0",
    "eslint-plugin-node": "^8.0.1",
    "eslint-plugin-promise": "^4.0.1",
    "eslint-plugin-react": "^7.17.0",
    "eslint-plugin-standard": "^4.0.0",
    "http-server": "^14.1.1",
    "prettier": "^2.3.1"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "workspaces": [
    "cli",
    "fs",
    "geo",
    "geometry",
    "jot",
    "op",
    "ops",
    "server",
    "sys",
    "threejs",
    "ux",
    "web"
  ]
}
